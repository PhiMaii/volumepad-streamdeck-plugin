				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/counter/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Change Volume",
			"UUID": "net.phimai.volumepad.streamdeck-remote.change-volume",
			"Icon": "imgs/actions/counter/icon",
			"Tooltip": "Increase or decrease master volume by a configured step.",
			"PropertyInspectorPath": "ui/change-volume.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/counter/key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Connection Status",
			"UUID": "net.phimai.volumepad.streamdeck-remote.connection-status",
			"Icon": "imgs/actions/counter/icon",
			"Tooltip": "Displays backend/device connection state.",
			"PropertyInspectorPath": "ui/connection-status.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/counter/key",
					"TitleAlignment": "middle"
				}
			]
		},
		{
			"Name": "Change Settings",
			"UUID": "net.phimai.volumepad.streamdeck-remote.change-settings",
			"Icon": "imgs/actions/counter/icon",
			"Tooltip": "Apply one selected backend setting on key press.",
			"PropertyInspectorPath": "ui/change-settings.html",
